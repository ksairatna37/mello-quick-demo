AZURE_DEPLOYMENT_NAME=gpt-5.2-chat
AZURE_API_VERSION=2024-12-01-preview
MELLO_SYSTEM_PROMPT=

# English Voice (Hume EVI)
HUME_API_KEY=
HUME_CONFIG_ID=
