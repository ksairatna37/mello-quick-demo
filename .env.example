# Backend-only Azure OpenAI config (safe for App Service Configuration / Key Vault references)
AZURE_OPENAI_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_DEPLOYMENT_NAME=gpt-5.2-chat
AZURE_API_VERSION=2024-12-01-preview

# Optional frontend override if backend runs on a different host
VITE_API_BASE_URL=

# Voice mode still uses browser-side Hume key in current implementation
VITE_HUME_API_KEY=
VITE_HUME_CONFIG_ID=
